# Copy this file to .env before running locally.
# The values below are safe defaults for local development.

PORT=3000

# Long random string for signing session cookies (change in production)
SESSION_SECRET=dev-secret-change-in-production-min-32-chars-xk9q2w

# Token that an external bot must send in the x-bot-token header.
# The web bot form (bot.html) does NOT need this — it uses /api/intake directly.
BOT_API_TOKEN=dev-bot-token-change-in-production

NODE_ENV=development
